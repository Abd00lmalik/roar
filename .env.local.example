# ══════════════════════════════════════════════════════════════════════════════
# ROAR Stadium v2 — Environment Variables
# Circle × X Layer Architecture
#
# Copy this file to .env.local and fill in all values before running locally.
# Never commit .env.local — it contains secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── Video ─────────────────────────────────────────────────────────────────────
# Optional — override the default /videos/stadium-bg.mp4 with a CDN URL
NEXT_PUBLIC_STADIUM_VIDEO_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Production URL or http://localhost:3000 for local dev
NEXTAUTH_URL=https://roartube.vercel.app
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# WalletConnect/Reown Project ID (from cloud.reown.com)
# If left blank, it defaults to the hardcoded ID: 2f05ae7c3f314f5f896f7bf9bb6f6e41
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Circle (server-only) ──────────────────────────────────────────────────────
# From https://console.circle.com/ → Developer → API Keys
CIRCLE_API_KEY=
# 32-byte hex — register this in Circle console → Entity Secret Ciphertext
CIRCLE_ENTITY_SECRET=
# UUID of the Wallet Set — create via Circle API or scripts/create-wallet-set.js
CIRCLE_WALLET_SET_ID=
# sandbox | production
CIRCLE_ENVIRONMENT=sandbox

# Circle wallet IDs for platform splits (server-only)
# Receives 10% fan pool slice from every streaming second
PLATFORM_POOL_WALLET=
# Receives 5% treasury slice from every streaming second
PLATFORM_TREASURY_WALLET=

# ── Supabase ──────────────────────────────────────────────────────────────────
# From Vercel → Storage → Supabase → Project Settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── X Layer — Deployer ────────────────────────────────────────────────────────
# Private key of the platform deployer wallet (used to mint passports, settle weeks)
# Must be funded with OKB for gas on X Layer Testnet
# NEVER expose to browser — only used in server API routes
PLATFORM_DEPLOYER_PRIVATE_KEY=
# X Layer Testnet RPC (default: https://testrpc.xlayer.tech)
NEXT_PUBLIC_XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
NEXT_PUBLIC_XLAYER_CHAIN_ID=195

# ── X Layer — Contract Addresses (set after deploy) ───────────────────────────
# Run: npx hardhat run contracts/scripts/deploy.ts --network xlayer-testnet --config contracts/hardhat.config.ts
NEXT_PUBLIC_FAN_PASSPORT_ADDRESS=
NEXT_PUBLIC_WATCH_LEADERBOARD_ADDRESS=
NEXT_PUBLIC_FAN_REWARDS_POOL_ADDRESS=
NEXT_PUBLIC_BILLING_CONTROLLER_ADDRESS=

# ── X Layer — Legacy Vault Contracts (existing system) ────────────────────────
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
VAULT_ADDRESS=
USDC_ADDRESS=

# ── Cloudflare Stream (video delivery) ────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=
