# ─── Video ───────────────────────────────────────────────────────────────────
# Optional — override /public/videos/stadium-bg.mp4 with a CDN URL
NEXT_PUBLIC_STADIUM_VIDEO_URL=

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://roartube.vercel.app
NEXTAUTH_SECRET=                          # openssl rand -base64 32

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Circle (Developer-Controlled Wallets) ────────────────────────────────────
# From https://console.circle.com/ → Developer → API Keys
CIRCLE_API_KEY=
# 32-byte hex entity secret from Circle console
CIRCLE_ENTITY_SECRET=
# UUID of the Wallet Set created in Circle console
CIRCLE_WALLET_SET_ID=
# sandbox | production
CIRCLE_ENVIRONMENT=sandbox

# ─── Chain / Treasury ─────────────────────────────────────────────────────────
# Fan Rewards Pool on X Layer Testnet (server-side)
XCHAIN_FAN_POOL_ADDRESS=
# Platform treasury address (server-side)
PLATFORM_TREASURY_ADDRESS=
# X Layer Testnet RPC
XCHAIN_RPC_URL=https://testrpc.xlayer.tech

# ─── Public chain vars (exposed to browser) ───────────────────────────────────
NEXT_PUBLIC_XCHAIN_POOL_ADDRESS=
NEXT_PUBLIC_TREASURY_ADDRESS=

# ─── Blockchain (X Layer Testnet) ─────────────────────────────────────────────
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
VAULT_ADDRESS=
DEPLOYER_PRIVATE_KEY=
TREASURY_ADDRESS=
FAN_REWARDS_ADDRESS=
SETTLER_ADDRESS=
NEXT_PUBLIC_XLAYER_RPC_URL=https://testrpc.xlayer.tech
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
USDC_ADDRESS=
SETTLER_PRIVATE_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cloudflare Stream ────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=

# ─── Database (optional direct connection) ────────────────────────────────────
# DATABASE_URL=
